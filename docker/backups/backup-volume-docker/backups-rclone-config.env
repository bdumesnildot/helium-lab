BACKUP_SOURCES=/backup/rclone-config
BACKUP_FILENAME='daily-backups-rclone-config-backup-%Y-%m-%dT%H-%M-%S.archive'
BACKUP_PRUNING_PREFIX='daily-backups-rclone-config-backup-'
BACKUP_RETENTION_DAYS='7'
BACKUP_STOP_DURING_BACKUP_LABEL=rclone-service
EXEC_LABEL=rclone
BACKUP_CRON_EXPRESSION='0 3 * * *'
