BACKUP_SOURCES=/backup/filebrowser-quantum-data
BACKUP_FILENAME='daily-cloud-filebrowser-quantum-data-backup-%Y-%m-%dT%H-%M-%S.archive'
BACKUP_PRUNING_PREFIX='daily-cloud-filebrowser-quantum-data-backup-'
BACKUP_RETENTION_DAYS='7'
BACKUP_STOP_DURING_BACKUP_LABEL=filebrowser-quantum-service
EXEC_LABEL=filebrowser-quantum
BACKUP_CRON_EXPRESSION='0 3 * * *'
