BACKUP_SOURCES=/backup/immich-postgresql-dump
BACKUP_FILENAME='daily-auth-immich-postgresql-dump-backup-%Y-%m-%dT%H-%M-%S.archive'
BACKUP_PRUNING_PREFIX='daily-auth-immich-postgresql-dump-backup-'
BACKUP_RETENTION_DAYS='7'
BACKUP_STOP_DURING_BACKUP_LABEL=immich-postgresql-service
EXEC_LABEL=immich-postgresql
BACKUP_CRON_EXPRESSION='0 3 * * *'
