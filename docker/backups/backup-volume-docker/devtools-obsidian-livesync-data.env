BACKUP_SOURCES=/backup/obsidian-livesync-etc
BACKUP_FILENAME='daily-cloud-obsidian-livesync-etc-backup-%Y-%m-%dT%H-%M-%S.archive'
BACKUP_PRUNING_PREFIX='daily-cloud-obsidian-livesync-etc-backup-'
BACKUP_RETENTION_DAYS='7'
BACKUP_STOP_DURING_BACKUP_LABEL=obsidian-livesync-service
EXEC_LABEL=obsidian-livesync
BACKUP_CRON_EXPRESSION='0 3 * * *'
