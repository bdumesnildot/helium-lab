BACKUP_SOURCES=/backup/opencode-config
BACKUP_FILENAME='daily-cloud-opencode-config-backup-%Y-%m-%dT%H-%M-%S.archive'
BACKUP_PRUNING_PREFIX='daily-cloud-opencode-config-backup-'
BACKUP_RETENTION_DAYS='7'
BACKUP_STOP_DURING_BACKUP_LABEL=opencode-service
EXEC_LABEL=opencode
BACKUP_CRON_EXPRESSION='0 3 * * *'
