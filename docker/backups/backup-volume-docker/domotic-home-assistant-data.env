BACKUP_SOURCES=/backup/home-assistant-data
BACKUP_FILENAME='daily-domotic-home-assistant-data-backup-%Y-%m-%dT%H-%M-%S.archive'
BACKUP_PRUNING_PREFIX='daily-domotic-home-assistant-data-backup-'
BACKUP_RETENTION_DAYS='7'
BACKUP_STOP_DURING_BACKUP_LABEL=home-assistant-service
EXEC_LABEL=home-assistant
BACKUP_CRON_EXPRESSION='0 3 * * *'
