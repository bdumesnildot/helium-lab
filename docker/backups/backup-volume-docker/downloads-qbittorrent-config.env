BACKUP_SOURCES=/backup/qbittorrent-config
BACKUP_FILENAME='daily-downloads-qbittorrent-config-backup-%Y-%m-%dT%H-%M-%S.archive'
BACKUP_PRUNING_PREFIX='daily-downloads-qbittorrent-config-backup-'
BACKUP_RETENTION_DAYS='7'
BACKUP_STOP_DURING_BACKUP_LABEL=qbittorrent-service
EXEC_LABEL=qbittorrent
BACKUP_CRON_EXPRESSION='0 3 * * *'
