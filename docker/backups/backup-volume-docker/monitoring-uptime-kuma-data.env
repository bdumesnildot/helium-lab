BACKUP_SOURCES=/backup/uptime-kuma-data
BACKUP_FILENAME='daily-monitoring-uptime-kuma-data-backup-%Y-%m-%dT%H-%M-%S.archive'
BACKUP_PRUNING_PREFIX='daily-monitoring-uptime-kuma-data-backup-'
BACKUP_RETENTION_DAYS='7'
BACKUP_STOP_DURING_BACKUP_LABEL=uptime-kuma-service
EXEC_LABEL=uptime-kuma
BACKUP_CRON_EXPRESSION='0 3 * * *'
