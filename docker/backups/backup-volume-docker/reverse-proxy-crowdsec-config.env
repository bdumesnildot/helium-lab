BACKUP_SOURCES=/backup/crowdsec-data
BACKUP_FILENAME='daily-cloud-crowdsec-data-backup-%Y-%m-%dT%H-%M-%S.archive'
BACKUP_PRUNING_PREFIX='daily-cloud-crowdsec-data-backup-'
BACKUP_RETENTION_DAYS='7'
BACKUP_STOP_DURING_BACKUP_LABEL=crowdsec-service
EXEC_LABEL=crowdsec
BACKUP_CRON_EXPRESSION='0 3 * * *'
