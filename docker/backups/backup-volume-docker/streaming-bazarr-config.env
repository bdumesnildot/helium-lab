BACKUP_SOURCES=/backup/bazarr-config
BACKUP_FILENAME='daily-streaming-bazarr-config-backup-%Y-%m-%dT%H-%M-%S.archive'
BACKUP_PRUNING_PREFIX='daily-streaming-bazarr-config-backup-'
BACKUP_RETENTION_DAYS='7'
BACKUP_STOP_DURING_BACKUP_LABEL=bazarr-service
EXEC_LABEL=bazarr
BACKUP_CRON_EXPRESSION='0 3 * * *'

BACKUP_EXCLUDE_REGEXP="/cache/"
