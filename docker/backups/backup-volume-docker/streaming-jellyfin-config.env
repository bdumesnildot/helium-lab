BACKUP_SOURCES=/backup/jellyfin-config
BACKUP_FILENAME='daily-streaming-jellyfin-config-backup-%Y-%m-%dT%H-%M-%S.archive'
BACKUP_PRUNING_PREFIX='daily-streaming-jellyfin-config-backup-'
BACKUP_RETENTION_DAYS='7'
BACKUP_STOP_DURING_BACKUP_LABEL=jellyfin-service
EXEC_LABEL=jellyfin
BACKUP_CRON_EXPRESSION='0 3 * * *'
