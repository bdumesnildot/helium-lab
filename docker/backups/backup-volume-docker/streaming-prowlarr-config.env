BACKUP_SOURCES=/backup/prowlarr-config
BACKUP_FILENAME='daily-streaming-prowlarr-config-backup-%Y-%m-%dT%H-%M-%S.archive'
BACKUP_PRUNING_PREFIX='daily-streaming-prowlarr-config-backup-'
BACKUP_RETENTION_DAYS='7'
BACKUP_STOP_DURING_BACKUP_LABEL=prowlarr-service
EXEC_LABEL=prowlarr
BACKUP_CRON_EXPRESSION='0 3 * * *'
