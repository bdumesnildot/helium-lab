BACKUP_SOURCES=/backup/radarr-config
BACKUP_FILENAME='daily-streaming-radarr-config-backup-%Y-%m-%dT%H-%M-%S.archive'
BACKUP_PRUNING_PREFIX='daily-streaming-radarr-config-backup-'
BACKUP_RETENTION_DAYS='7'
BACKUP_STOP_DURING_BACKUP_LABEL=radarr-service
EXEC_LABEL=radarr
BACKUP_CRON_EXPRESSION='0 3 * * *'
