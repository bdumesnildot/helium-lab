BACKUP_SOURCES=/backup/riven-backend-data
BACKUP_FILENAME='daily-streaming-riven-data-backup-%Y-%m-%dT%H-%M-%S.archive'
BACKUP_PRUNING_PREFIX='daily-streaming-riven-data-backup-'
BACKUP_RETENTION_DAYS='7'
BACKUP_STOP_DURING_BACKUP_LABEL=riven-service
EXEC_LABEL=riven
BACKUP_CRON_EXPRESSION='0 3 * * *'
