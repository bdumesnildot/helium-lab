BACKUP_SOURCES=/backup/riven-frontend-data
BACKUP_FILENAME='daily-streaming-riven-frontend-data-backup-%Y-%m-%dT%H-%M-%S.archive'
BACKUP_PRUNING_PREFIX='daily-streaming-riven-frontend-data-backup-'
BACKUP_RETENTION_DAYS='7'
BACKUP_STOP_DURING_BACKUP_LABEL=riven-frontend-service
EXEC_LABEL=riven-frontend
BACKUP_CRON_EXPRESSION='0 3 * * *'
c
