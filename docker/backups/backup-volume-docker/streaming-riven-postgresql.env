BACKUP_SOURCES=/backup/riven-postgresql-dump
BACKUP_FILENAME='daily-streaming-riven-postgresql-dump-backup-%Y-%m-%dT%H-%M-%S.archive'
BACKUP_PRUNING_PREFIX='daily-streaming-riven-postgresql-dump-backup-'
BACKUP_RETENTION_DAYS='7'
BACKUP_STOP_DURING_BACKUP_LABEL=riven-postgresql-service
EXEC_LABEL=riven-postgresql
BACKUP_CRON_EXPRESSION='0 3 * * *'
