BACKUP_SOURCES=/backup/seerr-config
BACKUP_FILENAME='daily-streaming-seerr-config-backup-%Y-%m-%dT%H-%M-%S.archive'
BACKUP_PRUNING_PREFIX='daily-streaming-seerr-config-backup-'
BACKUP_RETENTION_DAYS='7'
BACKUP_STOP_DURING_BACKUP_LABEL=seerr-service
EXEC_LABEL=seerr

BACKUP_CRON_EXPRESSION='0 3 * * *'
