BACKUP_SOURCES=/backup/sonarr-config
BACKUP_FILENAME='daily-streaming-sonarr-config-backup-%Y-%m-%dT%H-%M-%S.archive'
BACKUP_PRUNING_PREFIX='daily-streaming-sonarr-config-backup-'
BACKUP_RETENTION_DAYS='7'
BACKUP_STOP_DURING_BACKUP_LABEL=sonarr-service
EXEC_LABEL=sonarr
BACKUP_CRON_EXPRESSION='0 3 * * *'

BACKUP_EXCLUDE_REGEXP="/MediaCover/"
